rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ────────────────────────────────────────────────────────
    // Only the owner can read or write their own profile document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Cards (subcollection) ────────────────────────────────────────────────
    // Only the owner can read, create, update, or delete their own cards.
    match /users/{uid}/cards/{cardId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Shares ───────────────────────────────────────────────────────────────
    // Anyone (including unauthenticated users) can read a share by its ID
    // so that public share links work without requiring sign-in.
    //
    // Only authenticated users may create a share, and the document MUST
    // record their own uid as `userId` — prevents impersonation.
    //
    // Only the original creator may delete their share document.
    //
    // No update is allowed — shares are immutable once created.
    match /shares/{shareId} {
      allow read: if true;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(["userId", "cardId", "createdAt"]);

      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

  }
}
