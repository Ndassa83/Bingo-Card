rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ────────────────────────────────────────────────────────
    // Any authenticated user can read profiles (needed to show owner name on shared cards).
    // Only the owner can write their own profile.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Cards (subcollection) ────────────────────────────────────────────────
    match /users/{uid}/cards/{cardId} {
      function isOwner() {
        return request.auth != null && request.auth.uid == uid;
      }
      function isEditor() {
        return request.auth != null
          && request.auth.token.email != null
          && resource.data.editorEmails.hasAny([request.auth.token.email]);
      }
      function isViewer() {
        return request.auth != null
          && request.auth.token.email != null
          && resource.data.viewerEmails.hasAny([request.auth.token.email]);
      }

      // Read: owner, anyone with a public share link, or email-invited users
      allow read: if isOwner()
                  || resource.data.shareId != null
                  || isEditor()
                  || isViewer();

      // Owner has full write access (create, update, delete)
      allow write: if isOwner();

      // Editors can update everything except delete
      allow update: if isEditor();

      // Any invitee can remove only their own email (self-revoke access)
      allow update: if request.auth != null
        && request.auth.token.email != null
        && (resource.data.editorEmails.hasAny([request.auth.token.email])
            || resource.data.viewerEmails.hasAny([request.auth.token.email]))
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['editorEmails', 'viewerEmails', 'updatedAt'])
        && resource.data.editorEmails.hasAll(request.resource.data.editorEmails)
        && resource.data.viewerEmails.hasAll(request.resource.data.viewerEmails);
    }

    // ── Collection group read rule ───────────────────────────────────────────
    // Allows useSharedCards collection group queries to work across all users
    match /{path=**}/cards/{cardId} {
      allow read: if request.auth != null
                  && request.auth.token.email != null
                  && (resource.data.editorEmails.hasAny([request.auth.token.email])
                      || resource.data.viewerEmails.hasAny([request.auth.token.email]));
    }

    // ── Shares ───────────────────────────────────────────────────────────────
    match /shares/{shareId} {
      allow read: if true;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(["userId", "cardId", "createdAt"]);

      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

  }
}
